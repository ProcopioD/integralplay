{
  "info": {
    "name": "IntegralPlay API Tests Completo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "POST Login Cliente",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"email\": \"joao@email.com\", \"senha\": \"senha123\"}" },
        "url": "http://localhost:3000/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login retorna status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Login retorna token JWT', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property('token');",
              "  pm.collectionVariables.set('token_cliente', json.token);",
              "});",
              "pm.test('Login retorna dados do usuário', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.usuario).to.have.property('email');",
              "  pm.expect(json.usuario.perfil).to.equal('cliente');",
              "});"
            ]
          }
        }
      ]
    },
    {
