              "  if (json.length > 0) pm.expect(json[0]).to.have.property('preco_hora');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Criar Reserva",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token_cliente}}" }
        ],
        "body": { "mode": "raw", "raw": "{\"quadra_id\": 1, \"data\": \"2026-12-20\", \"hora_inicio\": \"14:00\", \"hora_fim\": \"15:00\", \"tipo\": \"pontual\"}" },
        "url": "http://localhost:3000/reservas"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Criar reserva retorna 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "pm.test('Reserva retorna ID e valor', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property('reserva_id');",
              "  pm.expect(json).to.have.property('valor_total');",
              "  pm.collectionVariables.set('reserva_id', json.reserva_id);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Pagamento",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token_cliente}}" }
        ],
        "body": { "mode": "raw", "raw": "{\"reserva_id\": {{reserva_id}}, \"metodo\": \"pix\"}" },
        "url": "http://localhost:3000/pagamentos"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Pagamento retorna 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Pagamento aprovado com sucesso', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.pagamento.status).to.equal('aprovado');",
              "  pm.expect(json.pagamento.metodo).to.equal('pix');",
              "});"
            ]
          }
        }
      ]
    },
