            ]
          }
        }
      ]
    },
    {
      "name": "GET Espaços (público)",
      "request": {
        "method": "GET",
        "url": "http://localhost:3000/espacos"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('GET espaços retorna status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Retorna lista de espaços', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.be.an('array');",
              "  pm.expect(json.length).to.be.above(0);",
              "});",
              "pm.test('Cada espaço tem nome e cidade', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json[0]).to.have.property('nome');",
              "  pm.expect(json[0]).to.have.property('cidade');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET Quadras do Espaço 1",
      "request": {
        "method": "GET",
        "url": "http://localhost:3000/quadras/espaco/1"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('GET quadras retorna status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Retorna lista de quadras', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.be.an('array');",
              "});",
              "pm.test('Quadra tem preço por hora', function () {",
